{
  "rewrites": [
    {
      "source": "/",
      "destination": "/prototype/index.html"
    },
    {
      "source": "/pages/:path*",
      "destination": "/prototype/pages/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/prototype/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}