{
  "rewrites": [
    {
      "source": "/",
      "destination": "/prototype/one-click-dev-standalone.html"
    },
    {
      "source": "/(.*)",
      "destination": "/prototype/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}