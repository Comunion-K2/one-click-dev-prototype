{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/prototype/index.html"
    },
    {
      "src": "/pages/(.*)",
      "dest": "/prototype/pages/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/prototype/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}